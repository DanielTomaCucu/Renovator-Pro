# Copiază în `.env` (gitignorat) și completează. Valorile de mai jos sunt pentru DEV local.
# NU comite niciodată `.env` cu valori reale.

# --- Postgres (docker-compose) ---
POSTGRES_DB=renovatorpro
POSTGRES_USER=renovatorpro
POSTGRES_PASSWORD=renovatorpro

# --- Backend (profil prod; pe dev valorile vin din application-dev.yml) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/renovatorpro
SPRING_DATASOURCE_USERNAME=renovatorpro
SPRING_DATASOURCE_PASSWORD=renovatorpro

# Domeniul Vercel real al frontend-ului (fără protocol duplicat, fără trailing slash, fără wildcard).
# Pe dev, allowlist-ul e deja localhost:3001 (application-dev.yml) — nu setat aici.
APP_CORS_ALLOWED_ORIGINS=https://renovator-pro.vercel.app

# --- Auth (Faza 5) ---
# Secret HS256 pentru JWT — minim 256 biți (32+ caractere). Generează unul propriu, ex:
# openssl rand -base64 48
JWT_SECRET=schimba-ma-cu-un-secret-de-minim-256-biti-generat-random

# --- Email (resetare parolă) ---
# Domeniul Vercel real al frontend-ului — folosit pt. linkul din emailul de resetare parolă.
# Pe dev are fallback (localhost:3001), pe prod e obligatoriu.
APP_FRONTEND_URL=https://renovator-pro.vercel.app
# Cheie API Resend (https://resend.com/api-keys) — fără ea, linkul de resetare ajunge doar în logul
# backend-ului (mod dev), nu se trimite email real.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Expeditorul emailurilor — implicit onboarding@resend.dev (funcțional fără verificare de domeniu).
EMAIL_FROM_ADDRESS=onboarding@resend.dev
