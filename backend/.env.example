# Copiază în `.env` (gitignorat) și completează. Valorile de mai jos sunt pentru DEV local.
# NU comite niciodată `.env` cu valori reale.

# --- Postgres (docker-compose) ---
POSTGRES_DB=renovatorpro
POSTGRES_USER=renovatorpro
POSTGRES_PASSWORD=renovatorpro

# --- Backend (profil prod; pe dev valorile vin din application-dev.yml) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/renovatorpro
SPRING_DATASOURCE_USERNAME=renovatorpro
SPRING_DATASOURCE_PASSWORD=renovatorpro

# --- Auth (Faza 5 — încă neutilizate) ---
# JWT_SECRET=schimba-ma-cu-un-secret-de-minim-256-biti
