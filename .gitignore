# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.
# Monorepo: patterns are unrooted so they match in frontend/ and backend/ alike.

# dependencies
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage

# next.js (ancorate la frontend/ — „out" ca nume generic ar prinde pachete Java ca application/port/out)
.next/
/frontend/out/

# production / build output
/frontend/build/
target/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDEs
.idea/
*.iml

# java / maven (backend)
!maven-wrapper.jar
