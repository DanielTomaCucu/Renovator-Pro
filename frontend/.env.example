# Copiază în `.env.local` (gitignorat) pentru dezvoltare locală.

# URL-ul backend-ului Spring Boot (implicit http://localhost:8080 dacă lipsește).
NEXT_PUBLIC_API_URL=http://localhost:8080

# "true" = folosește datele mock in-memory (fără backend). Implicit: conectat la API real.
NEXT_PUBLIC_USE_MOCK_DATA=false
